@model IPTV_Website.Models.HomeViewModel

@{
    ViewData["Title"] = "Live Channels";
    ViewData["ActivePage"] = "home";
}
<section class="home-page">
    <section class="hero-panel tv-focus-scope" id="homeHeroActions" data-focus-scope data-scope-id="home-hero" data-nav-type="horizontal-actions" data-nav-up="self" data-nav-down="#homeViewAllSection">
        <div class="hero-backdrop" style="background-image:url('@Model.HeroChannel.ImageUrl')"></div>
        <div class="hero-content">
            <div class="eyebrow">Good Evening</div>
            <div class="hero-meta tight-meta">
                <span class="pill live">LIVE NOW</span>
                <span class="pill audience">@Model.HeroChannel.ViewerLabel</span>
                <span class="pill">@Model.HeroChannel.Category</span>
            </div>
            <h1 class="hero-title">@Model.HeroChannel.Name</h1>
            <p class="hero-copy">@Model.HeroChannel.Description</p>
            <div class="hero-actions compact-actions">
                <a class="tv-button tv-focusable primary-action" id="homeWatchNow" data-autofocus asp-controller="Home" asp-action="Player" asp-route-ChannelId="@Model.HeroChannel.Id" >Watch Now</a>
            </div>
        </div>
    </section>

    <section class="content-section home-trending-section">
        <div class="section-header slim-header home-trending-header">
            <div class="section-heading-row with-dot">
                <span class="section-badge-icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M21 6h-3V4a1 1 0 00-1-1H7a1 1 0 00-1 1v2H3a1 1 0 00-1 1v10a1 1 0 001 1h18a1 1 0 001-1V7a1 1 0 00-1-1zM8 18v-6h8v6H8z" fill="currentColor" />
                    </svg>
                </span>
                <h2>Trending Now</h2>
            </div>
            <div class="tv-focus-scope" id="homeViewAllSection" data-focus-scope data-nav-type="single-item" data-nav-up="#homeHeroActions" data-nav-down="#homeTrendingGrid">
                <button class="section-link tv-focusable" id="homeViewAllButton" type="button" data-toast="More channels will be available later">View All</button>
            </div>
        </div>
        <div class="channel-grid tv-focus-scope" id="homeTrendingGrid" data-focus-scope data-nav-type="grid" data-nav-up="#homeViewAllSection">
            @foreach (var channel in Model.TrendingChannels)
            {
                var cardId = $"homeTrendCard-{channel.Id}";
                <article class="channel-card tv-card tv-focusable" id="@cardId" tabindex="0" data-nav-role="card" data-href="/Home/Player?ChannelId=@(channel.Id)">
                    <div class="channel-thumb" style="background-image:url('@channel.ImageUrl')">
                        <span class="badge live">LIVE</span>
                        <span class="badge quality">@channel.Quality</span>
                    </div>
                    <div class="channel-body compact-body">
                        <div class="channel-title-row">
                            <h3>@channel.Name</h3>
                            <button class="favorite-badge tv-focusable icon-only @(channel.IsFavorite ? "is-active" : string.Empty)" type="button" data-nav-role="subaction" data-parent-card="#@cardId" data-favorite-toggle data-favorite-state="@(channel.IsFavorite.ToString().ToLowerInvariant())" data-favorite-label="@channel.Name" aria-label="Toggle favorite">
                                <span class="favorite-heart" aria-hidden="true">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M12 21s-7.5-4.73-9.33-7.02C1.12 11.61 2.5 7.5 6 6.5 8 5.9 10 7 12 9c2-2 4-3.1 6-2.5 3.5 1 4.88 5.11 3.33 7.48C19.5 16.27 12 21 12 21z" fill="currentColor" />
                                    </svg>
                                </span>
                            </button>
                        </div>
                        <p>@channel.Category</p>
                        <div class="channel-meta compact-meta"><span>@channel.ViewerLabel</span><span>@channel.Language</span></div>
                    </div>
                </article>
            }
        </div>
    </section>
</section>
