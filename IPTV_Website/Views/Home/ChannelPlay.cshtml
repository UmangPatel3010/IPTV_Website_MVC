@using IPTV_Website.Helpers
@model IPTV_Website.Models.ChannelPlayViewModel

@{
    var epgChannel = Model.EpgData.FirstOrDefault();
    var programs = epgChannel?.Programs ?? new List<IPTV_Website.Models.ApiModels.Programs>();
    var currentProgram = programs.FirstOrDefault();
    var nextPrograms = programs.Skip(1).Take(4).ToList();

    ViewData["Title"] = $"Service {Model.ServiceNo} Player";
    ViewData["ActivePage"] = "player";
    ViewData["BackUrl"] = "/Home/Dashboard";
    ViewData["SkipInitialFocus"] = true;
}
<section class="player-page">
    <div class="player-canvas">
        <video id="drmPlayer" autoplay style="width: 100%; height: 100%;object-fit: fill;" />
             
    </div>
    <div class="player-layer">
        <div class="player-topbar tv-focus-scope" id="playerTopSection" data-focus-scope data-nav-type="single-item" data-nav-down="#playerChannelSwitchSection">
            <a class="player-back tv-focusable" id="playerBackButton" href='/Home/Dashboard' data-nav-down="#playerChannelUp" aria-label="Back to dashboard test">
                <span class="player-back-icon" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
            </a>
            <div class="player-status"><span class="pill live live-float">LIVE</span></div>
        </div>

        <div class="player-bottom-dock">
            <div class="player-brand-card">
                <div class="channel-logo">@("S" + Model.ServiceNo)</div>
                <div class="player-number-stack tv-focus-scope" id="playerChannelSwitchSection" data-focus-scope data-nav-type="vertical-list" data-nav-up="#playerBackButton" data-nav-down="#playerToolbarSection">
                    <a class="tv-focusable" id="playerChannelUp" aria-label="Previous channel" data-nav-left="self" data-nav-up="#playerBackButton" data-nav-right="#playerToolbarSection" asp-controller="Home" asp-action="ChannelPlay" asp-route-serviceNo="@Model.PrevServiceNo">
                        <img src="/assets/mock/channel_arrow_up.svg" alt="Arrow Up">
                    </a>
                    <div class="player-channel-number large">@Model.ServiceNo</div>
                    <a class="tv-focusable" id="playerChannelDown" aria-label="Next channel" data-nav-left="self" data-nav-down="self" data-nav-right="#playerToolbarSection" asp-controller="Home" asp-action="ChannelPlay" asp-route-serviceNo="@Model.NextServiceNo">
                        <img src="/assets/mock/channel_arrow_down.svg" alt="Arrow Down">
                    </a>
                </div>
            </div>

            <div class="player-program-block">
                <div class="player-title-line">
                    <h1>@(epgChannel?.DisplayName ?? epgChannel?.Channel ?? $"Service {Model.ServiceNo}")</h1>
                    <span class="player-show-name">@(currentProgram?.Name ?? "Program info not available")</span>
                </div>
                <div class="player-schedule-row">
                    @if (currentProgram != null)
                    {
                        <div class="schedule-pill live-now">@($"{currentProgram.StartDate:hh:mm tt} - {currentProgram.StopDate:hh:mm tt}")</div>
                    }
                    @foreach (var next in nextPrograms)
                    {
                        <div class="schedule-pill next-show">@($"{next.StartDate:hh:mm tt} - {next.Name}")</div>
                    }
                </div>
            </div>

            <div class="player-controls tv-focus-scope" id="playerToolbarSection" data-focus-scope data-nav-type="horizontal-actions" data-nav-up="#playerBackButton" data-nav-down="self">
                <button class="control-button wide tv-focusable" id="openChannelList" type="button" data-nav-left="#playerChannelDown" data-nav-down="self" data-open-overlay="#channelOverlay">Channels</button>
                @* <button class="control-button tv-focusable" type="button" data-toast="Guide overlay is a demo action" data-nav-down="self">Guide</button> *@
                @* <button class="control-button tv-focusable" type="button" data-toast="Fullscreen is already represented in the demo" data-nav-down="self">Fullscreen</button> *@
            </div>
        </div>
    </div>

    <aside class="player-overlay" id="channelOverlay" data-overlay hidden>
        <div class="overlay-title"><h2>All Channels</h2></div>
        <label class="overlay-search tv-focusable" id="playerOverlaySearch" tabindex="0" data-nav-down="#playerChannelOverlayList" data-nav-up="self" data-toast="Search inside player will be connected later" aria-label="Search">
            <span class="search-leading" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zM10 14a4 4 0 110-8 4 4 0 010 8z" fill="currentColor" />
                </svg>
            </span>
            <input type="text" placeholder="Search" readonly aria-label="Search" />
        </label>
        <div class="channel-list tv-focus-scope" id="playerChannelOverlayList" data-focus-scope data-nav-type="vertical-list" data-nav-up="#playerOverlaySearch" data-nav-down="self">
            @foreach (var channel in Model.AllChannels)
            {
                <a class="channel-list-item tv-focusable @(channel.ServiceID == Model.ServiceNo ? "is-active" : string.Empty)" 
                   type="button" 
                   asp-controller="Home" 
                   asp-action="ChannelPlay" 
                   asp-route-serviceNo="@channel.ServiceID">
                    <span class="list-logo">@channel.AppDisplayName.Substring(0, Math.Min(2, channel.AppDisplayName.Length)).ToUpperInvariant()</span>
                    <span class="list-copy">
                        <span class="list-title">@channel.AppDisplayName</span>
                        <span class="list-meta">@channel.Category</span>
                    </span>
                    <span class="list-number">@channel.ServiceID</span>
                </a>
            }
        </div>
    </aside>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
                // ----------------------------
                // 1) Player UI state references
                // ----------------------------
                const playerPage = document.querySelector('.player-page');
                const hideDelayMs = 3000;
                let hideTimer;

                // -------------------------------------------------
                // 2) Focus/session behavior for ChannelPlay routing
                // -------------------------------------------------
                // Keys:
                // - channelPlayVisited: marks that user is already inside ChannelPlay flow
                // - channelPlayLastFocusId: remembers last focused channel control (up/down)
                const sessionFlagKey = 'channelPlayVisited';
                const lastFocusKey = 'channelPlayLastFocusId';

                // Focusable controls used by focus persistence logic
                const playerBackButton = document.getElementById('playerBackButton');
                const playerChannelUp = document.getElementById('playerChannelUp');
                const playerChannelDown = document.getElementById('playerChannelDown');

                // Utility: defer focus until DOM/layout settles
                const focusLater = (element) => {
                    if (!element) {
                        return;
                    }

                    requestAnimationFrame(() => {
                        requestAnimationFrame(() => {
                            element.focus({ preventScroll: true });
                        });
                    });
                };

                // Utility: clear player-only focus session flags
                const clearPlayerFocusSession = () => {
                    sessionStorage.removeItem(sessionFlagKey);
                    sessionStorage.removeItem(lastFocusKey);
                };

                // Utility: persist focus id when channel controls are focused/activated
                const persistLastFocus = (button) => {
                    if (!button) {
                        return;
                    }

                    const saveFocusId = () => sessionStorage.setItem(lastFocusKey, button.id);
                    button.addEventListener('focus', saveFocusId);
                    button.addEventListener('click', saveFocusId);
                };

                const isFirstVisit = !sessionStorage.getItem(sessionFlagKey);
                sessionStorage.setItem(sessionFlagKey, 'true');

                [playerChannelUp, playerChannelDown].forEach(persistLastFocus);

                // Keyboard activation support: persist/clear focus session on Enter
                document.addEventListener('keydown', (event) => {
                    if (event.key !== 'Enter') {
                        return;
                    }

                    const active = document.activeElement;
                    if (!active) {
                        return;
                    }

                    if (active.id === 'playerBackButton') {
                        clearPlayerFocusSession();
                        return;
                    }

                    if (active.id === 'playerChannelUp' || active.id === 'playerChannelDown') {
                        sessionStorage.setItem(lastFocusKey, active.id);
                    }
                });

                // Leaving player via back button click: clear ChannelPlay focus session
                if (playerBackButton) {
                    playerBackButton.addEventListener('click', clearPlayerFocusSession);
                }

                // Initial focus rule:
                // - first visit -> focus back button
                // - channel switch -> restore channel control focus
                if (isFirstVisit) {
                    focusLater(playerBackButton);
                } else {
                    if (playerBackButton) {
                        playerBackButton.removeAttribute('data-autofocus');
                    }

                    const restoreId = sessionStorage.getItem(lastFocusKey);
                    const restoreElement = (restoreId ? document.getElementById(restoreId) : null)
                        || playerChannelDown
                        || playerChannelUp;

                    focusLater(restoreElement);
                }

                // ---------------------------
                // 3) Player chrome auto-hide
                // ---------------------------
                // Hides overlay controls after inactivity and shows them on interaction/focus
                const showUi = () => {
                    if (!playerPage) {
                        return;
                    }

                    playerPage.classList.remove('is-ui-hidden');
                    clearTimeout(hideTimer);
                    hideTimer = setTimeout(() => playerPage.classList.add('is-ui-hidden'), hideDelayMs);
                };

                if (playerPage) {
                    ['mousemove', 'keydown', 'touchstart'].forEach(evt => playerPage.addEventListener(evt, showUi));
                    document.addEventListener('focusin', showUi);
                    showUi();
                }

                // ------------------------------
                // 4) Shaka player initialization
                // ------------------------------
                // Creates DRM player instance and loads the current channel URL
                const video = document.getElementById('drmPlayer');
                const player = new shaka.Player(video);

                player.addEventListener('error', e => console.error('Error:', e));

                // Force JSON header for ClearKey
                // player.getNetworkingEngine().registerRequestFilter((type, request) => {
                //     if (type === shaka.net.NetworkingEngine.RequestType.LICENSE) {
                //         request.headers['Content-Type'] = 'application/json';
                //         request.headers['IsApplication'] = 'app';
                //         request.headers['Token'] = 'xd2jsyci5WV+XGedvEfxOg==';
                //     }
                // });
        
                player.configure({
                    drm: {
                        servers: {
                            'org.w3.clearkey': '/Home/License'
                        }
                    }
                });

                try {
                    await player.load('@Model.ChannelUrl');
                    console.log('Loaded OK');
                } catch (e) {
                    console.error('Load Error:', e);
                }
            });
    </script>
}
