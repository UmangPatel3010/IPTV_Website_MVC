@inject IConfiguration Configuration
@using IPTV_Website.Helpers
@{
    var signalRHubUrl = Configuration["SignalR:HubUrl"] ?? string.Empty;
    var deviceNo = CommonVariables.getDeviceNo() ?? string.Empty;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@ViewData["Title"] - StreamHub TV</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @* <script src="https://cdnjs.cloudflare.com/ajax/libs/shaka-player/4.16.3/shaka-player.ui.min.js"></script> *@
    @* <script src="https://googleapis.com"></script> *@
    
    @await RenderSectionAsync("Styles", required: false)

</head>
<body class="app-shell signalr-pending @(Context.Request.Path.ToString().Contains("/Player") ? "player-mode" : "sidebar-collapsed")"
      data-page="@((string?)ViewData["ActivePage"] ?? "home")"
      data-back-url="@((string?)ViewData["BackUrl"] ?? "/")">
    <div id="signalrGate" class="signalr-gate-overlay">
        <div id="signalrGateCard" class="signalr-gate-card">Connecting to server...</div>
    </div>
    @{
        var activePage = ((string?)ViewData["ActivePage"] ?? string.Empty).ToLowerInvariant();
    }
    @if (!Context.Request.Path.ToString().Contains("/Player"))
    {
        <aside class="side-nav tv-focus-scope" id="sideNavSection" data-focus-scope data-scope-id="side-nav" data-nav-type="vertical-menu" data-nav-right="#homeHeroActions">
            <a class="brand tv-focusable" href='/'>
                <span class="brand-mark">S</span>
                <span class="side-nav-copy"><strong>StreamHub</strong><small>TV Demo</small></span>
            </a>
            <button class="menu-toggle tv-focusable" id="sidebarToggle" type="button" data-sidebar-toggle data-autofocus>
                <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6" /></svg></span>
                <span class="side-nav-copy">Browse</span>
            </button>
            <nav class="nav-links">
                <a class="nav-item tv-focusable @(activePage == "home" ? "active" : string.Empty)" id="navHome" data-nav-right="#homeHeroActions" href='/'>
                    <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h18v10H3z" /><path d="M8 20h8" /><path d="M12 17v3" /></svg></span>
                    <span class="side-nav-copy">News</span>
                </a>
                <a class="nav-item tv-focusable @(activePage == "search" ? "active" : string.Empty)" id="navSearch" data-nav-right="#searchBarSection" asp-controller="Home" asp-action="Search">
                    <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="6" /><path d="M20 20l-4.35-4.35" /></svg></span>
                    <span class="side-nav-copy">Search</span>
                </a>
                <button class="nav-item tv-focusable" type="button" data-nav-right="#homeHeroActions" data-toast="Sports category will be connected later"><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M6 7l5-3 7 4-1 8-5 4-6-3-1-8z" /><path d="M9 9l6 6" /><path d="M15 9l-6 6" /></svg></span><span class="side-nav-copy">Sports</span></button>
                <button class="nav-item tv-focusable" type="button" data-nav-right="#homeHeroActions" data-toast="Movies section is a demo placeholder"><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="5" width="16" height="14" rx="2" /><path d="M8 5v14" /><path d="M16 5v14" /><path d="M4 10h16" /></svg></span><span class="side-nav-copy">Movies</span></button>
                <button class="nav-item tv-focusable" type="button" data-nav-right="#homeHeroActions" data-toast="Entertainment section is a demo placeholder"><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M7 5h10l2 4H5l2-4z" /><path d="M6 9v8a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V9" /><path d="M10 12h4" /></svg></span><span class="side-nav-copy">Entertainment</span></button>
                <button class="nav-item tv-focusable" type="button" data-nav-right="#homeHeroActions" data-toast="Documentary section will be connected later"><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h9a3 3 0 0 1 3 3v13H9a3 3 0 0 0-3 0z" /><path d="M6 4v16" /></svg></span><span class="side-nav-copy">Documentary</span></button>
                <button class="nav-item tv-focusable" type="button" data-nav-right="#homeHeroActions" data-toast="Music section is a demo placeholder"><span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M14 5v10" /><path d="M14 5l6-2v10" /><circle cx="8" cy="17" r="3" /><circle cx="20" cy="15" r="3" /></svg></span><span class="side-nav-copy">Music</span></button>
                <a class="nav-item tv-focusable @(activePage == "favorites" ? "active" : string.Empty)" id="navFavorites" data-nav-right="#favoritesPrimarySection" href='/Home/Favorites'>
                    <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-6.7-4.35-9.33-8.12C.78 10.12 1.78 6.5 5.28 5.4c2.1-.67 4.2.06 5.72 1.92 1.52-1.86 3.62-2.59 5.72-1.92 3.5 1.1 4.5 4.72 2.61 7.48C18.7 16.65 12 21 12 21z" /></svg></span>
                    <span class="side-nav-copy">Favorites</span>
                </a>
                <a class="nav-item tv-focusable @(activePage == "subscriberdetails" ? "active" : string.Empty)" id="navSettings" data-nav-right="#settingsPrimarySection" href='/Home/SubscriberDetails'>
                    <span class="nav-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 8.92 4.6H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9c.36.61.93 1 1.6 1H21a2 2 0 0 1 0 4h-.09c-.67 0-1.24.39-1.51 1z" /></svg></span>
                    <span class="side-nav-copy">Subscriber Details</span>
                </a>
            </nav>
        </aside>
    }
    <main class="page-shell" role="main">
        @RenderBody()
    </main>
    <div class="toast-stack" id="toastStack" aria-live="polite" aria-atomic="true"></div>
    <script>
            window.tvSignalRConfig = window.tvSignalRConfig || {};
            window.tvSignalRConfig.getSignalRHubUrl = function () {
                return @Html.Raw(System.Text.Json.JsonSerializer.Serialize(signalRHubUrl));
            };
            window.tvSignalRConfig.getDeviceNo = function () {
                return @Html.Raw(System.Text.Json.JsonSerializer.Serialize(deviceNo));
            };
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/signalr-client.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
